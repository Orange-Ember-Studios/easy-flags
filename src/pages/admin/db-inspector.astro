---
import BaseLayout from "@/layouts/BaseLayout.astro";
import DatabaseInspector from "@/components/react/DatabaseInspector";
import { requireAuth, getLoginUrl } from "@/utils/auth-redirect";
import { isSuperUser } from "@/utils/permissions";
import { getUserFromContext } from "@/utils/auth";

export const prerender = false;

// Require authentication
if (!requireAuth(Astro)) {
  return Astro.redirect(getLoginUrl(Astro));
}

// Get user and check permissions
const user = getUserFromContext(Astro);
const isDevelopment = !import.meta.env.PROD;

// Allow access if in development OR if the user is a super user
if (!isDevelopment && (!user || !isSuperUser(user))) {
  return Astro.redirect("/forbidden");
}
---

<BaseLayout
  title="Database Inspector - Management"
  description="System database inspection and management tool"
  includeHeader={true}
>
  <DatabaseInspector client:load />
</BaseLayout>
