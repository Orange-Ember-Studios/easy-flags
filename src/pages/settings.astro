---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SettingsView from "@/components/react/SettingsView";
import { requireAuth, getLoginUrl } from "@/utils/auth-redirect";
import { getTranslator } from "@/infrastructure/i18n/astro";

const { t } = getTranslator(Astro.request);

export const prerender = false;

// Require authentication
if (!requireAuth(Astro)) {
  return Astro.redirect(getLoginUrl(Astro));
}
---

<BaseLayout title={`${t('settings.title')} - Easy Flags`} includeHeader={true}>
  <SettingsView client:load />
</BaseLayout>
