---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getTranslator } from "@/infrastructure/i18n/astro";

const { t } = getTranslator(Astro.request);
---

<BaseLayout title={`404 - ${t('errors.404.title')}`} includeHeader={true}>
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="max-w-md w-full text-center">
      <div class="mb-8">
        <div class="text-6xl font-bold text-cyan-500 mb-4">404</div>
        <h1 class="text-4xl font-bold text-white mb-4">{t('errors.404.title')}</h1>
        <p class="text-slate-400 mb-8">
          {t('errors.404.description')}
        </p>
      </div>

      <div class="space-y-3">
        <a href="/spaces" class="btn-primary block w-full text-center py-3">
          {t('errors.404.goBackSpaces')}
        </a>
        <a
          href="/"
          class="btn-secondary block w-full text-center py-3 border border-slate-600"
        >
          {t('errors.404.goHome')}
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
