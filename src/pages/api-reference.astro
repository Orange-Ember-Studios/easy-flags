---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import { getTranslator } from "@/infrastructure/i18n/astro";

const { t } = getTranslator(Astro.request);
---

<BaseLayout title={t('apiReference.title')} includeHeader={true}>
  <article class="max-w-4xl mx-auto py-12">
    <h1 class="text-4xl font-bold text-gradient mb-6">{t('apiReference.title')}</h1>

    <div class="card space-y-6">
      <section>
        <h2 class="text-2xl font-bold text-cyan-300 mb-3">{t('apiReference.authTitle')}</h2>
        <p class="text-slate-400 mb-4">
          {t('apiReference.authDesc')}
        </p>
        <pre
          class="bg-slate-900 p-4 rounded-lg overflow-x-auto"><code>Authorization: Bearer YOUR_JWT_TOKEN</code></pre>
      </section>

      <section>
        <h3 class="text-xl font-bold text-cyan-300 mb-3">
          POST /api/auth/login
        </h3>
        <p class="text-slate-400 mb-4">
          {t('apiReference.loginDesc')}
        </p>
      </section>

      <section>
        <h3 class="text-xl font-bold text-cyan-300 mb-3">GET /api/spaces</h3>
        <p class="text-slate-400 mb-4">
          {t('apiReference.spacesDesc')}
        </p>
      </section>

      <section>
        <h3 class="text-xl font-bold text-cyan-300 mb-3">
          POST /api/spaces/:spaceId/features
        </h3>
        <p class="text-slate-400 mb-4">
          {t('apiReference.createFeatureDesc')}
        </p>
      </section>

      <section>
        <h3 class="text-xl font-bold text-cyan-300 mb-3">
          GET /api/spaces/:spaceId/environments
        </h3>
        <p class="text-slate-400 mb-4">{t('apiReference.getEnvsDesc')}</p>
      </section>
    </div>
  </article>
</BaseLayout>
