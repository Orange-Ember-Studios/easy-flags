---
import PaymentResultLayout from "@/layouts/PaymentResultLayout.astro";

const successUrl = new URL(Astro.request.url).searchParams.get("success");
const collection = new URL(Astro.request.url).searchParams.get("collection");
---

<PaymentResultLayout
  title="Payment Successful"
  description="Your payment was processed successfully"
>
  <div class="max-w-md w-full">
    <!-- Success Icon -->
    <div class="flex justify-center mb-8">
      <div
        class="relative w-24 h-24 bg-green-500/10 rounded-full flex items-center justify-center border-2 border-green-500/30"
      >
        <svg
          class="w-12 h-12 text-green-500"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M5 13l4 4L19 7"></path>
        </svg>
      </div>
    </div>

    <!-- Content -->
    <div class="text-center space-y-4 mb-8">
      <h1 class="text-3xl font-bold text-white">Payment Successful!</h1>
      <p class="text-slate-300">
        Thank you for your purchase. Your subscription has been activated and
        you can now enjoy all the features.
      </p>

      {
        collection && (
          <div class="bg-slate-800/50 border border-slate-700/50 rounded-lg p-4 mt-6">
            <p class="text-sm text-slate-400">Collection ID</p>
            <p class="text-lg font-mono text-green-400 break-all">
              {collection}
            </p>
          </div>
        )
      }
    </div>

    <!-- Action Buttons -->
    <div class="space-y-3">
      <a
        href="/spaces"
        class="block w-full bg-gradient-to-r from-cyan-500 to-cyan-600 hover:from-cyan-600 hover:to-cyan-700 text-white font-semibold py-3 px-4 rounded-lg text-center transition"
      >
        Go to Dashboard
      </a>
      <a
        href="/billing"
        class="block w-full bg-slate-700 hover:bg-slate-600 text-white font-semibold py-3 px-4 rounded-lg text-center transition"
      >
        Back to Billing
      </a>
    </div>

    <!-- Information -->
    <div class="mt-8 text-center text-sm text-slate-400">
      <p>
        A confirmation email has been sent to your registered email address.
      </p>
    </div>
  </div>
</PaymentResultLayout>
