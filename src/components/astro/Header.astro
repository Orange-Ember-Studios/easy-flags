---
import { getUserFromContext } from "@/utils/auth";
import HeaderDropdown from "@/components/react/shared/HeaderDropdown";

const user = getUserFromContext(Astro);
// Get current path safely - for prerendered pages, this will be undefined
let currentPath = "";
try {
  const url = new URL(Astro.request.url);
  currentPath = url.pathname;
} catch (e) {
  // In prerendered context, Astro.request.url won't be available
  currentPath = "";
}

const isActive = (path: string) => {
  if (!currentPath) return false; // Don't highlight links in prerendered pages
  return currentPath === path;
};

const navItems = {
  pricing: {
    href: "/billing",
    label: "Pricing",
    showFor: !user,
  },
  spaces: {
    href: "/spaces",
    label: "Spaces",
    showFor: !!user,
  },
  metrics: {
    href: "/metrics",
    label: "Metrics",
    showFor: !!user,
  },
  settings: {
    href: "/settings",
    label: "Settings",
    showFor: !!user,
  },
  docs: {
    href: "/docs",
    label: "Docs",
    showFor: true,
  },
  login: {
    href: "/login",
    label: "Login",
    showFor: !user,
  },
};

const getNavLinkClass = (href: string) => {
  const isCurrentPath = isActive(href);
  if (user) {
    return `transition ${
      isCurrentPath
        ? "text-cyan-300 font-semibold"
        : "text-slate-300 hover:text-cyan-400"
    }`;
  } else {
    return `transition ${
      isCurrentPath
        ? "text-cyan-300 font-semibold"
        : "text-cyan-100 hover:text-cyan-300"
    }`;
  }
};
---

<header class="sticky top-0 z-50 w-full border-b border-white/5 bg-[#06080f]/80 backdrop-blur-xl">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-cyan-400 to-blue-600 flex items-center justify-center shadow-lg shadow-cyan-500/20">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21a2 2 0 012 2v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
        </svg>
      </div>
      <a
        href="/"
        class="text-2xl font-bold tracking-tight bg-gradient-to-r from-white via-white to-slate-400 bg-clip-text text-transparent font-display"
      >
        Easy Flags
      </a>
    </div>

    <div class="hidden md:flex gap-10 items-center">
      <div class="flex items-center gap-8">
        {
          navItems.pricing.showFor && (
            <a
              href={navItems.pricing.href}
              class="text-sm font-medium text-slate-400 hover:text-white transition-colors"
            >
              {navItems.pricing.label}
            </a>
          )
        }

        {
          navItems.spaces.showFor && (
            <a
              href={navItems.spaces.href}
              class="text-sm font-medium text-slate-400 hover:text-white transition-colors"
            >
              {navItems.spaces.label}
            </a>
          )
        }

        {
          navItems.metrics.showFor && (
            <a
              href={navItems.metrics.href}
              class="text-sm font-medium text-slate-400 hover:text-white transition-colors"
            >
              {navItems.metrics.label}
            </a>
          )
        }

        {
          navItems.settings.showFor && (
            <a
              href={navItems.settings.href}
              class="text-sm font-medium text-slate-400 hover:text-white transition-colors"
            >
              {navItems.settings.label}
            </a>
          )
        }

        <a
          href={navItems.docs.href}
          class="text-sm font-medium text-slate-400 hover:text-white transition-colors"
        >
          {navItems.docs.label}
        </a>
      </div>

      <div class="h-6 w-px bg-white/10 mx-2"></div>

      <div class="flex items-center gap-4">
        {
          user ? (
            <HeaderDropdown client:load username={user.username} />
          ) : (
            <>
              <a
                href={navItems.login.href}
                class="text-sm font-semibold text-white hover:text-cyan-400 transition-colors px-4"
              >
                {navItems.login.label}
              </a>
              <a href="/create-account" class="btn-primary text-sm !px-6 !py-2.5">
                Get Started
              </a>
            </>
          )
        }
      </div>
    </div>
  </nav>
</header>
