<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Feature Flags UI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/style.css" />
  </head>
  <body
    class="antialiased bg-gradient-to-br from-slate-900 via-slate-800 to-cyan-950"
  >
    <div class="root h-full">
      <%- include('partials/header') %>

      <div class="container mt-4 sm:mt-6 p-4">
        <!-- Hero -->

        <section class="mt-6">
          <div
            class="hero-juicy flex flex-col-reverse md:flex-row items-center justify-between gap-8 rounded-2xl p-6 md:p-12 shadow-2xl relative overflow-hidden"
            style="
              background: linear-gradient(
                120deg,
                rgba(8, 47, 73, 0.98) 0%,
                rgba(6, 182, 212, 0.13) 40%,
                rgba(96, 165, 250, 0.1) 70%,
                rgba(124, 58, 237, 0.09) 100%
              );
            "
          >
            <div class="flex-1 z-10 text-center md:text-left">
              <h1
                class="text-4xl md:text-5xl font-extrabold mb-4 bg-gradient-to-r from-cyan-400 via-blue-400 to-cyan-300 bg-clip-text text-transparent drop-shadow-lg"
              >
                Launch new ideas
                <span class="whitespace-nowrap">without the stress.</span>
              </h1>
              <p
                class="text-lg md:text-xl text-slate-300 mb-6 max-w-lg mx-auto md:mx-0"
              >
                Release in smaller steps, stay in control, and adapt instantly.
              </p>
              <div
                class="flex flex-col sm:flex-row gap-3 justify-center md:justify-start"
              >
                <a
                  href="/create-account"
                  class="bg-cyan-500/90 hover:bg-cyan-400 text-white px-6 py-3 rounded-lg font-semibold shadow-lg hover:shadow-xl transition transform hover:-translate-y-1 w-full sm:w-auto text-lg"
                  aria-label="Create account"
                >
                  Create Account
                </a>
                <a
                  href="/login"
                  class="border border-cyan-400/30 text-cyan-100 px-6 py-3 rounded-lg hover:bg-cyan-400/10 transition w-full sm:w-auto text-lg"
                  aria-label="Login"
                >
                  Login
                </a>
              </div>
            </div>
            <div class="flex-1 flex items-center justify-center relative z-10">
              <img
                class="hero-illustration drop-shadow-2xl max-w-full md:max-w-lg lg:max-w-xl animate-fade-in"
                src="/illustrations/hero.svg"
                alt="Feature rollout illustration"
                style="z-index: 2"
              />
            </div>
          </div>
        </section>

        <!-- Quick Start -->
        <section class="mt-10 mb-8" aria-labelledby="quickstart-heading">
          <div
            class="rounded-xl bg-slate-800/80 border border-cyan-700/30 shadow-lg p-6 md:p-10 w-full"
          >
            <h2
              id="quickstart-heading"
              class="text-2xl font-bold text-cyan-300 mb-3 flex items-center gap-2"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="inline w-7 h-7 text-cyan-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 16h-1v-4h-1m1-4h.01M12 20a8 8 0 100-16 8 8 0 000 16z"
                />
              </svg>
              Quick Start
            </h2>
            <ol class="list-decimal list-inside text-slate-200 space-y-2 mb-4">
              <li>
                <span class="font-semibold text-cyan-200">Clone the repo:</span>
                <code
                  class="bg-slate-900 rounded p-2 mt-1 text-cyan-200 text-sm overflow-x-auto block"
                  >git clone &lt;your-repo-url&gt;</code
                >
              </li>
              <li>
                <span class="font-semibold text-cyan-200"
                  >Install dependencies:</span
                >
                <code
                  class="bg-slate-900 rounded p-2 mt-1 text-cyan-200 text-sm overflow-x-auto block"
                  >npm install</code
                >
              </li>
              <li>
                <span class="font-semibold text-cyan-200"
                  >Start the app (auto-initializes DB):</span
                >
                <code
                  class="bg-slate-900 rounded p-2 mt-1 text-cyan-200 text-sm overflow-x-auto block"
                  >npm start</code
                >
              </li>
              <li>
                <span class="font-semibold text-cyan-200"
                  >Create a migration placeholder:</span
                >
                <code
                  class="bg-slate-900 rounded p-2 mt-1 text-cyan-200 text-sm overflow-x-auto block"
                  >npm run migration:create -- add_feature_x</code
                >
              </li>
            </ol>
            <div class="text-slate-400 text-sm">
              <span class="font-semibold text-cyan-200">Tip:</span> Edit the
              generated migration file in
              <span class="font-mono text-cyan-300">src/migrations/</span> and
              run <span class="font-mono text-cyan-300">npm start</span> to
              apply it automatically.
            </div>
          </div>
        </section>

        <!-- Why Love Section (Improved) -->
        <section class="why-love-section mt-6">
          <h2 class="section-title mb-1">Why people love using Easy Flags</h2>
          <p class="section-subtitle mb-6">
            Simple, clear, and built for fast teams.
          </p>
          <div class="why-love-cards flex flex-col sm:flex-row gap-4 mt-2">
            <div
              class="why-love-card flex-1"
              tabindex="0"
              aria-label="Faster releases: Ship in smaller steps, more often."
            >
              <div class="why-love-icon-wrapper icon-cyan">
                <img
                  class="icon"
                  src="/icons/bolt.svg"
                  alt=""
                  aria-hidden="true"
                />
              </div>
              <div>
                <h3 class="card-title">Faster releases</h3>
                <p class="card-desc">Ship in smaller steps, more often.</p>
              </div>
            </div>
            <div
              class="why-love-card flex-1"
              tabindex="0"
              aria-label="More control: Toggle features instantly, no redeploy required."
            >
              <div class="why-love-icon-wrapper icon-green">
                <img
                  class="icon"
                  src="/icons/target.svg"
                  alt=""
                  aria-hidden="true"
                />
              </div>
              <div>
                <h3 class="card-title">More control</h3>
                <p class="card-desc">
                  Toggle features instantly, no redeploy required.
                </p>
              </div>
            </div>
            <div
              class="why-love-card flex-1"
              tabindex="0"
              aria-label="Better UX: Delight users with seamless updates."
            >
              <div class="why-love-icon-wrapper icon-purple">
                <img
                  class="icon"
                  src="/icons/heart.svg"
                  alt=""
                  aria-hidden="true"
                />
              </div>
              <div>
                <h3 class="card-title">Better UX</h3>
                <p class="card-desc">Delight users with seamless updates.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Comparisons -->
        <section class="mt-12">
          <div class="mb-8">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-3">
              Measurable impact that matters
            </h2>
            <p class="text-base text-slate-300">
              See the real-world improvements teams experience with Easy Flags
            </p>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-16">
            <!-- Launches Card -->
            <div
              class="rounded-xl border border-cyan-500/20 bg-gradient-to-br from-slate-800/50 to-slate-900/50 p-8 flex flex-col min-h-full hover:border-cyan-500/40 transition"
            >
              <div class="mb-6">
                <div class="flex items-start justify-between mb-4">
                  <div class="flex items-center gap-3">
                    <div
                      class="w-12 h-12 rounded-full flex items-center justify-center text-xl bg-cyan-500/20 border border-cyan-500/30"
                    >
                      <img
                        class="icon"
                        src="/icons/check.svg"
                        alt="Faster launches"
                      />
                    </div>
                    <div>
                      <p class="text-sm font-semibold text-cyan-300">
                        LAUNCHES
                      </p>
                      <p class="text-xs text-slate-400 mt-0.5">
                        Time to release
                      </p>
                    </div>
                  </div>
                  <span
                    class="inline-block px-3 py-1.5 rounded-full bg-cyan-500/20 border border-cyan-500/30 text-cyan-300 text-xs font-semibold"
                    >5x Faster</span
                  >
                </div>
                <p class="text-sm text-slate-300 leading-relaxed">
                  Move from risky all-at-once launches to progressive rollouts
                  with complete control over your release strategy.
                </p>
              </div>
              <div
                class="w-full flex items-center justify-center py-6 flex-grow"
              >
                <img
                  class="max-w-full h-auto block"
                  src="/illustrations/compare-launches.svg"
                  alt="Launches before and after comparison: 10 days reduced to 2 days"
                />
              </div>
            </div>

            <!-- Reliability Card -->
            <div
              class="rounded-xl border border-green-500/20 bg-gradient-to-br from-slate-800/50 to-slate-900/50 p-8 flex flex-col min-h-full hover:border-green-500/40 transition"
            >
              <div class="mb-6">
                <div class="flex items-start justify-between mb-4">
                  <div class="flex items-center gap-3">
                    <div
                      class="w-12 h-12 rounded-full flex items-center justify-center text-xl bg-green-500/20 border border-green-500/30"
                    >
                      <img
                        class="icon"
                        src="/icons/lifebuoy.svg"
                        alt="Better reliability"
                      />
                    </div>
                    <div>
                      <p class="text-sm font-semibold text-green-300">
                        RELIABILITY
                      </p>
                      <p class="text-xs text-slate-400 mt-0.5">
                        Incidents per month
                      </p>
                    </div>
                  </div>
                  <span
                    class="inline-block px-3 py-1.5 rounded-full bg-green-500/20 border border-green-500/30 text-green-300 text-xs font-semibold"
                    >80% Fewer</span
                  >
                </div>
                <p class="text-sm text-slate-300 leading-relaxed">
                  Reduce downtime by switching unstable features off instantly
                  instead of waiting for lengthy redeploys.
                </p>
              </div>
              <div
                class="w-full flex items-center justify-center py-6 flex-grow"
              >
                <img
                  class="max-w-full h-auto block"
                  src="/illustrations/compare-reliability.svg"
                  alt="Reliability before and after: 5 incidents reduced to 1"
                />
              </div>
            </div>

            <!-- Product Fit Card -->
            <div
              class="rounded-xl border border-purple-500/20 bg-gradient-to-br from-slate-800/50 to-slate-900/50 p-8 flex flex-col min-h-full hover:border-purple-500/40 transition"
            >
              <div class="mb-6">
                <div class="flex items-start justify-between mb-4">
                  <div class="flex items-center gap-3">
                    <div
                      class="w-12 h-12 rounded-full flex items-center justify-center text-xl bg-purple-500/20 border border-purple-500/30"
                    >
                      <img
                        class="icon"
                        src="/icons/sparkles.svg"
                        alt="Better product fit"
                      />
                    </div>
                    <div>
                      <p class="text-sm font-semibold text-purple-300">
                        PRODUCT FIT
                      </p>
                      <p class="text-xs text-slate-400 mt-0.5">
                        Features validated
                      </p>
                    </div>
                  </div>
                  <span
                    class="inline-block px-3 py-1.5 rounded-full bg-purple-500/20 border border-purple-500/30 text-purple-300 text-xs font-semibold"
                    >3.75x Growth</span
                  >
                </div>
                <p class="text-sm text-slate-300 leading-relaxed">
                  Replace guesswork with fast experiments and measurable
                  learning across different environments.
                </p>
              </div>
              <div
                class="w-full flex items-center justify-center py-6 flex-grow"
              >
                <img
                  class="max-w-full h-auto block"
                  src="/illustrations/compare-productfit.svg"
                  alt="Product fit before and after: 20% to 75%"
                />
              </div>
            </div>

            <!-- Deployment Frequency Card -->
            <div
              class="rounded-xl border border-cyan-500/20 bg-gradient-to-br from-slate-800/50 to-slate-900/50 p-8 flex flex-col min-h-full hover:border-cyan-500/40 transition"
            >
              <div class="mb-6">
                <div class="flex items-start justify-between mb-4">
                  <div class="flex items-center gap-3">
                    <div
                      class="w-12 h-12 rounded-full flex items-center justify-center text-xl bg-cyan-500/20 border border-cyan-500/30"
                    >
                      <img
                        class="icon"
                        src="/icons/bolt.svg"
                        alt="Faster deployments"
                      />
                    </div>
                    <div>
                      <p class="text-sm font-semibold text-cyan-300">
                        DEPLOYMENT
                      </p>
                      <p class="text-xs text-slate-400 mt-0.5">
                        Frequency per week
                      </p>
                    </div>
                  </div>
                  <span
                    class="inline-block px-3 py-1.5 rounded-full bg-cyan-500/20 border border-cyan-500/30 text-cyan-300 text-xs font-semibold"
                    >10x More</span
                  >
                </div>
                <p class="text-sm text-slate-300 leading-relaxed">
                  Deploy changes multiple times a day instead of waiting for
                  scheduled weekly release windows.
                </p>
              </div>
              <div
                class="w-full flex items-center justify-center py-6 flex-grow"
              >
                <img
                  class="max-w-full h-auto block"
                  src="/illustrations/compare-frequency.svg"
                  alt="Deployment frequency before and after: 1 per week to 10+ per day"
                />
              </div>
            </div>
          </div>
        </section>

        <!-- CTA: focused -->
        <section class="mt-8" aria-labelledby="cta-heading">
          <div
            class="rounded-lg bg-white/4 p-6 flex flex-col md:flex-row items-center justify-between gap-4"
          >
            <div>
              <h4 id="cta-heading" class="text-lg font-semibold text-white">
                Ready to get started?
              </h4>
              <p class="text-sm text-slate-400">
                Create flags and ship faster with confidence.
              </p>
            </div>
            <div class="flex gap-3">
              <a
                href="/create-account"
                class="bg-cyan-500 text-white px-4 py-2 rounded-md shadow-sm inline-block"
                aria-label="Create account"
              >
                Create Account
              </a>
              <a
                href="/api-reference"
                class="text-sm text-slate-300 self-center underline"
                aria-label="API Reference"
                >API Reference</a
              >
            </div>
          </div>
        </section>
      </div>
      <%- include('partials/footer') %>
    </div>
  </body>
</html>
