<div class="page space-y-4">
  <section class="bg-white/5 rounded-lg p-6">
    <div
      class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4"
    >
      <h3>Environments</h3>
      <% if (permissions && permissions.includes('create_environments')) { %>
      <button
        id="openCreateEnv"
        class="bg-cyan-500 text-white px-4 py-2 rounded-md w-full sm:w-auto"
        type="button"
      >
        Create Environment
      </button>
      <% } %>
    </div>
  </section>

  <section class="bg-white/5 rounded-lg p-6">
    <h3 class="mb-4">Existing Environments</h3>
    <div class="overflow-x-auto">
      <table
        id="envsTable"
        class="min-w-full table-auto divide-y divide-white/6"
      >
        <thead>
          <tr>
            <th class="text-left p-3 sm:p-4">Environment</th>
            <th class="text-center p-3 sm:p-4 w-24 sm:w-32">Actions</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </section>
</div>

<script src="/js/environments.js"></script>
