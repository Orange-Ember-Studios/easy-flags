<div class="page space-y-4">
  <section class="bg-white/5 rounded-lg p-6">
    <div
      class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4"
    >
      <div class="flex-1 min-w-0">
        <h3 class="mb-4">Manage Feature Flags</h3>
        <select id="envSelect" class="w-full sm:max-w-xs"></select>
      </div>
      <button
        id="openCreateFeature"
        class="bg-cyan-500 text-white px-4 py-2 rounded-md w-full sm:w-auto flex-shrink-0"
        type="button"
      >
        Create Feature
      </button>
    </div>
  </section>

  <section class="bg-white/5 rounded-lg p-6">
    <div class="overflow-x-auto">
      <table
        id="flagsTable"
        class="min-w-full table-auto divide-y divide-white/6"
      >
        <thead>
          <tr>
            <th class="text-left p-3 sm:p-4 min-w-32">Feature</th>
            <th class="text-left p-3 sm:p-4 min-w-40 hidden sm:table-cell">
              Description
            </th>
            <th class="text-center p-3 sm:p-4 w-20">Active</th>
            <th class="text-center p-3 sm:p-4 w-16 sm:w-20">Actions</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </section>
</div>

<script src="/js/environments.js"></script>
<script src="/js/features.js"></script>
<script src="/js/flags.js"></script>
