<!-- Simplified Register Screen -->
<div class="fixed inset-0 flex items-center justify-center bg-black/40">
  <div class="bg-slate-900/90 backdrop-blur-sm p-8 rounded-lg shadow-lg w-full max-w-md">
    <div class="flex items-center gap-3 mb-6 justify-center">
      <div class="w-10 h-10 rounded-md bg-cyan-500 flex items-center justify-center text-white font-bold">FF</div>
      <h2 class="text-white text-2xl font-bold">Create Account</h2>
    </div>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-4 text-red-400 text-center font-semibold"><%= error %></div>
    <% } %>
    <form method="POST" action="/auth/register" class="space-y-4">
      <input
        id="username"
        name="username"
        placeholder="Username"
        type="text"
        autocomplete="username"
        required
        class="block w-full bg-white/5 text-white placeholder-slate-400 px-3 py-2 rounded-md border border-white/10 focus:outline-none focus:ring-2 focus:ring-cyan-500"
      />
      <input
        id="password"
        name="password"
        placeholder="Password"
        type="password"
        autocomplete="new-password"
        required
        class="block w-full bg-white/5 text-white placeholder-slate-400 px-3 py-2 rounded-md border border-white/10 focus:outline-none focus:ring-2 focus:ring-cyan-500"
      />
      <button
        class="bg-cyan-500 text-white px-4 py-2 rounded-md hover:shadow-md transition w-full font-semibold"
        type="submit"
      >
        Create Account
      </button>
    </form>
    <div class="mt-4 text-center">
      <a href="/" class="text-cyan-400 hover:underline">Back to home</a>
    </div>
  </div>
</div>