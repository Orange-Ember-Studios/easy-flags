<!-- Header / Navigation (unified) -->
<div class="top flex items-center justify-between py-4">
  <div class="flex items-center gap-3 flex-1 min-w-0">
    <a href="/" class="logo header text-lg font-bold text-white no-underline" aria-label="Home">EF</a>
    <h2 class="text-base sm:text-xl md:text-2xl font-bold truncate">Easy Flags</h2>
  </div>

  <div class="flex items-center gap-2">
    <button
      id="hamburger"
      class="icon-btn sm:hidden"
      aria-label="Menu"
      aria-controls="mainNav"
      aria-expanded="false"
      type="button"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M3 6h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M3 12h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <!-- Nav menu (inside header; styled as drawer on mobile) -->
    <div class="nav-placeholder hidden sm:block" aria-hidden="true">
      <nav class="nav flex gap-2 items-center" id="mainNav" role="navigation" aria-label="Main navigation">
        <% if (typeof user !== 'undefined' && user) { %>
          <button data-nav="envs" type="button" class="nav-btn text-sm text-slate-200 px-3 py-1 hover:bg-white/2 rounded">Environments</button>
          <button data-nav="features" type="button" class="nav-btn text-sm text-slate-200 px-3 py-1 hover:bg-white/2 rounded">Feature Flags</button>
          <button data-nav="docs" type="button" class="nav-btn text-sm text-slate-200 px-3 py-1 hover:bg-white/2 rounded">Docs</button>
          <button id="btnLogout" type="button" class="nav-btn text-sm text-slate-200 px-3 py-1 hover:bg-white/2 rounded">Logout</button>
        <% } else { %>
          <button data-nav="pricing" type="button" class="nav-btn text-sm text-slate-200 px-3 py-1 hover:bg-white/2 rounded" onclick="window.location.href = '/billing'">Pricing</button>
          <button data-nav="docs" type="button" class="nav-btn text-sm text-slate-200 px-3 py-1 hover:bg-white/2 rounded" onclick="window.location.href = '/api/openapi.json'">API</button>
          <button data-nav="login" type="button" class="nav-btn text-sm text-slate-200 px-3 py-1 hover:bg-white/2 rounded" onclick="window.location.href = '/login'">Login</button>
        <% } %>
      </nav>
    </div>
  </div>

  <!-- Backdrop placeholder -->
  <div class="nav-backdrop-placeholder" aria-hidden="true">
    <div id="navBackdrop" class="nav-backdrop" aria-hidden="true"></div>
  </div>
</div>

<script src="/js/header.js"></script>
