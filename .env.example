PORT=3000

# Local SQLite Database (development)
DATABASE_URL=file:./data.db

# Turso Remote Database (production)
# DATABASE_URL=libsql://your-db-name-your-org.turso.io
# DATABASE_AUTH_TOKEN=eyJhbGciOiJFZENTU0EiLCJ0eXAiOiJKV1QifQ...

JWT_SECRET=change-me
ADMIN_USER=admin
ADMIN_PASS=password

# Wompi Configuration
# Get these from your Wompi dashboard at https://dashboard.wompi.co/
PUBLIC_WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_PRIVATE_KEY=prv_test_...
WOMPI_INTEGRITY_SECRET=test_integrity_...
WOMPI_EVENT_SECRET=test_event_...